"$EDITOR" \
+'set laststatus=0 |
  set shortmess=I  |
  set guicursor=a:ver100-blinkon0 |
  set noruler'             \
+"$hide_tildes"            \
+'noremap y "+y'           \
+"$*" \
+"$position_cmd" -
